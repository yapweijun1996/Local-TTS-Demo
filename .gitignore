# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
*.tsbuildinfo

# TTS model files (large; mount or download locally — keep the folder, not the weights)
models/*
!models/.gitkeep

# Generated audio output (privacy: never commit user-generated audio)
output/
data/tts-jobs/
*.wav
*.mp3
*.ogg

# Env / secrets
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Test / coverage
coverage/
.playwright/
.playwright-cli/
test-results/

# Allow small audio test fixtures (override the *.wav / output rules above)
!**/fixtures/
!**/fixtures/**
!**/__fixtures__/
!**/__fixtures__/**
.gstack/

# Python sidecar
__pycache__/
*.pyc
.venv/

# One-off engine evaluation environments (throwaway: venvs + downloaded model
# weights, several GB each). Not product code — recreate from the upstream
# repo if needed again (see memory: tts_voice_evaluation_findings.md).
services/*-eval/
